# DataSync - Market Data Layer
# Copy to .env and fill in your API keys.

# PostgreSQL / TimescaleDB
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_USER=datasync
POSTGRES_PASSWORD=datasync_secret
POSTGRES_DB=datasync
DATABASE_URL=postgresql+asyncpg://datasync:datasync_secret@timescaledb:5432/datasync

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=60
BARS_CACHE_TTL_SECONDS=300

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_EQUITIES=market.ticks.equities
KAFKA_TOPIC_CRYPTO=market.ticks.crypto
KAFKA_TOPIC_OPTIONS=market.ticks.options
KAFKA_TOPIC_ALTDATA=datasync.alt-data

# Alpaca (get free keys at alpaca.markets)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2
ALPACA_CRYPTO_STREAM_URL=wss://stream.data.alpaca.markets/v1beta3/crypto/us

# Polygon.io (get free key at polygon.io)
POLYGON_API_KEY=your_polygon_api_key
POLYGON_STREAM_URL=wss://socket.polygon.io/stocks

# Use mock WebSocket feeds in development (no real API keys needed)
USE_MOCK_FEEDS=true
MOCK_FEED_INTERVAL_MS=500

# NewsAPI (get free key at newsapi.org)
NEWS_API_KEY=your_newsapi_key
NEWS_FETCH_INTERVAL_MINUTES=15

# CoinGecko (free tier, no key required)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_FETCH_INTERVAL_MINUTES=5

# App
LOG_LEVEL=INFO
ENVIRONMENT=development

# Default symbols to subscribe on startup
DEFAULT_EQUITY_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,TSLA,SPY,QQQ
DEFAULT_CRYPTO_SYMBOLS=BTC/USD,ETH/USD,SOL/USD
DEFAULT_OPTIONS_SYMBOLS=

# Historical fetch
HISTORICAL_LOOKBACK_DAYS=365
